# Copy to .env and fill in. NEVER commit .env.

# SEC EDGAR requires a declared identity in the User-Agent (any real name + email works)
SEC_EDGAR_USER_AGENT="Your Name your.email@example.com"

# Groq — free tier at https://console.groq.com (needed from Day 26 for the deployed app)
GROQ_API_KEY=

# Reddit API (optional — only if using PRAW instead of a Kaggle dataset, Day 5)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT="FinSentinel/0.1 by your_reddit_username"
